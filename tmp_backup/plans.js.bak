const express = require('express');
const router = express.Router();
const pool = require('../db');

router.post('/', async (req, res) => {
  try {
    const { title, clientId, coachId, durationWeeks, goal, blocks, mealPlans } = req.body;
    const result = await pool.query(
      `
        INSERT INTO plans (title, client_id, coach_id, duration_weeks, goal, blocks, meal_plans)
        VALUES ($1, $2, $3, $4, $5, $6, $7)
        RETURNING *;
      `,
      [
        title,
        clientId,
        coachId,
        durationWeeks,
        goal,
        JSON.stringify(blocks || []),
        JSON.stringify(mealPlans || [])
      ]
    );
    res.status(201).json(result.rows[0]);
  } catch (err) {
    console.error('POST /api/plans error', err);
    res.status(500).json({ error: 'db error' });
  }
});

router.get('/', async (req, res) => {
  try {
    const result = await pool.query('SELECT * FROM plans ORDER BY created_at DESC LIMIT 100');
    res.json(result.rows);
  } catch (err) {
    console.error('GET /api/plans error', err);
    res.status(500).json({ error: 'db error' });
  }
});

module.exports = router;
